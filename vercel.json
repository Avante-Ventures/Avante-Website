{
  "framework": "vite",
  "installCommand": "pnpm install --config.dangerously-allow-all-builds=true --no-frozen-lockfile",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.avanteventures.com" }],
      "destination": "https://avanteventures.com/$1",
      "permanent": true
    },
    { "source": "/", "destination": "/en", "permanent": true }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

